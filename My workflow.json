    {
      "parameters": {
        "jsCode": "// 1. Obtenemos todo el paquete del Merge\nconst datos = $input.item.json;\n\n// 2. Extraemos y limpiamos los textos de las IAs (Ajusta los nombres si tu Merge los llamó distinto)\nconst textoAgente2 = datos.output || \"{}\"; // Ajustar si tienes otra variable para el Agente 2\nconst textoAgente3 = datos.output3 || \"{}\"; // Ajustar si tienes otra variable para el Agente 3\n\n// Convertimos a JSON real (Evitando errores si no encuentra nada)\nlet datosAgente2 = {};\nlet datosAgente3 = {};\ntry { datosAgente2 = JSON.parse(textoAgente2.replace(/```json|```/g, \"\").trim()); } catch (e) {}\ntry { datosAgente3 = JSON.parse(textoAgente3.replace(/```json|```/g, \"\").trim()); } catch (e) {}\n\n// Si tu Merge juntó los JSONs directamente en \"datos\" (sin variable output), usamos \"datos\"\nconst pago = (datos.condicion_pago || datosAgente2.condicion_pago || \"\").toLowerCase();\nconst garantia = (datos.garantia || datosAgente2.garantia || \"\").toLowerCase();\nconst penalidades = (datos.penalidades_retraso || datosAgente3.penalidades_retraso || \"\").toLowerCase();\n\n// 3. MOTOR DE SCORING V2 (Con Riesgo Legal)\nlet puntaje = 100;\n\n// Financiero\nif (pago.includes(\"100%\") || pago.includes(\"adelanto\")) puntaje -= 20; \nelse if (pago.includes(\"crédito\") || pago.includes(\"credito\") || pago.includes(\"días\")) puntaje += 10;\n\n// Comercial\nif (garantia.includes(\"no especifica\") || garantia.includes(\"n/a\") || garantia === \"\") puntaje -= 15;\n\n// Legal / Compliance (NUEVO)\nif (penalidades.includes(\"no especifica\") || penalidades.includes(\"n/a\")) {\n    puntaje -= 10; // Castigo por no aceptar penalidades por retraso\n}\n\n// Clasificamos el nivel de riesgo\nlet nivel_riesgo = \"Bajo\";\nif (puntaje < 70) nivel_riesgo = \"Alto\";\nelse if (puntaje < 90) nivel_riesgo = \"Medio\";\n\n// 4. Entregamos el Paquete Final Completo\nreturn {\n    json: {\n        proveedor: datos.proveedor,\n        ruc: datos.ruc,\n        precio_total: datos.precio_total || datos.monto_total,\n        condicion_pago: pago || \"No especifica\",\n        tiempo_entrega: datos.tiempo_entrega || datosAgente2.tiempo_entrega || \"No especifica\",\n        garantia: garantia || \"No especifica\",\n        validez_oferta: datos.validez_oferta || datosAgente3.validez_oferta || \"No especifica\",\n        penalidades_retraso: penalidades || \"No especifica\",\n        puntaje_ia: puntaje,\n        nivel_riesgo: nivel_riesgo\n    }\n};"
      },
