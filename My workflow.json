    {
      "parameters": {
        "jsCode": "// Tomamos el texto que soltó el AI Agent\nconst rawOutput = $input.first().json.output;\n\n// Limpiamos las marcas de bloque de código (```json ... ```) \n// que a veces pone la IA y convertimos a un objeto real\nconst cleanData = JSON.parse(rawOutput.replace(/```json|```/g, \"\").trim());\n\n// Formateamos el precio para que sea un número real (quitando comas)\nif (cleanData.precio_total) {\n  cleanData.precio_total = parseFloat(cleanData.precio_total.toString().replace(/,/g, ''));\n}\n\nreturn {\n  json: cleanData\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1184,
        160
